{
  "$schema": "./golden-tests.schema.json",
  "version": "2.0",
  "mcp_name": "Costa Rican Law MCP",
  "description": "Golden contract tests for the Costa Rican Law MCP -- 12 tests covering article retrieval, search, citation, cross-reference, and negative cases. Updated for full-corpus (16,724 laws, 120,455 provisions).",
  "tests": [
    {
      "id": "cr-001",
      "category": "article_retrieval",
      "description": "Retrieve data protection law Article 1 -- scope and purpose",
      "tool": "get_provision",
      "input": {
        "document_id": "cr-ley8968",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["garantizar", "datos personales", "protección"],
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "cr-002",
      "category": "article_retrieval",
      "description": "Retrieve Penal Code Article 196 bis -- computer crimes",
      "tool": "get_provision",
      "input": {
        "document_id": "cr-codigo-penal-4573",
        "section": "196 bis"
      },
      "assertions": {
        "result_not_empty": true,
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "cr-003",
      "category": "article_retrieval",
      "description": "Retrieve data protection law Article 5 -- consentimiento (consent)",
      "tool": "get_provision",
      "input": {
        "document_id": "cr-ley8968",
        "section": "5"
      },
      "assertions": {
        "result_not_empty": true,
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "cr-004",
      "category": "search",
      "description": "Full-text search for 'datos personales' returns relevant provisions",
      "tool": "search_legislation",
      "input": {
        "query": "datos personales"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["datos", "personales"]
      }
    },
    {
      "id": "cr-005",
      "category": "search",
      "description": "Full-text search for 'firma digital' returns e-signature provisions",
      "tool": "search_legislation",
      "input": {
        "query": "firma digital"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1
      }
    },
    {
      "id": "cr-006",
      "category": "search",
      "description": "Full-text search for 'telecomunicaciones' returns telecom provisions",
      "tool": "search_legislation",
      "input": {
        "query": "telecomunicaciones"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1
      }
    },
    {
      "id": "cr-007",
      "category": "article_retrieval",
      "description": "Retrieve Telecommunications Law Article 1 -- scope",
      "tool": "get_provision",
      "input": {
        "document_id": "cr-ley8642",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "cr-008",
      "category": "metadata",
      "description": "list_sources returns metadata for Costa Rican law data",
      "tool": "list_sources",
      "input": {},
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["CR"]
      }
    },
    {
      "id": "cr-009",
      "category": "article_retrieval",
      "description": "Retrieve Digital Signatures law Article 1 -- scope",
      "tool": "get_provision",
      "input": {
        "document_id": "cr-ley8454",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "cr-010",
      "category": "negative_test",
      "description": "Non-existent law returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "fictional-law-2099",
        "section": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "cr-011",
      "category": "negative_test",
      "description": "Malformed article number returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "cr-ley8968",
        "section": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "cr-012",
      "category": "list_sources",
      "description": "list_sources returns metadata including jurisdiction CR",
      "tool": "list_sources",
      "input": {},
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["CR"]
      }
    }
  ]
}
